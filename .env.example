# =========================================================================
# Stayful Intelligence — environment variables
# Copy to `.env.local` for local dev. Set the same vars on Vercel for prod.
# =========================================================================

# ── Supabase (auth + profiles DB) ────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe (subscription checkout + discount codes) ──────────────────────
# STRIPE_SECRET_KEY + STRIPE_PRO_PRICE_ID enable the API-based Checkout
# Session at /api/stripe/checkout, which auto-applies the discount code a user
# entered at signup (resolved against Stripe's promotion codes) and otherwise
# lets them enter one on Stripe's page. Create the codes in the Stripe
# Dashboard (Products → Coupons → Promotion codes). With either var unset,
# checkout falls back to the static NEXT_PUBLIC_STRIPE_PAYMENT_LINK.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
# Optional: static Stripe Payment Link used as the checkout fallback. Enable
# "Allow promotion codes" on it in the dashboard so codes work there too.
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=

# ── App ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── AI voice narrator (analyser summary — /api/summarise + /api/speak) ────
# Anthropic Claude generates the spoken summary of an analysis result.
ANTHROPIC_API_KEY=
# ElevenLabs reads the summary aloud. ELEVENLABS_VOICE_ID is optional — leave
# blank to use ElevenLabs' default "Rachel" voice, or set a branded/cloned
# voice ID. Without ELEVENLABS_API_KEY the narrator still shows the written
# summary; it just won't speak.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── Analyser data partners (required by /api/analyse) ────────────────────
AIRBTICS_API_KEY=
AIRBTICS_BASE_URL=
PROPERTYDATA_API_KEY=
GOOGLE_PLACES_API_KEY=
TICKETMASTER_API_KEY=

# Dev-only: lets scripts/calibrate.mjs bypass auth + trial gate on
# /api/analyse. Do NOT set on production.
CALIBRATION_BYPASS_SECRET=

# ── Monday CRM ───────────────────────────────────────────────────────────
# REQUIRED for trial signups to appear in Monday. Without this, the
# trial→Monday hook logs "[Monday] skipped — MONDAY_API_KEY not set" and
# silently does nothing. (MONDAY_API_TOKEN is accepted as a fallback name.)
# Used by src/lib/apis/monday.ts (trial signups) and /api/track (engagement).
MONDAY_API_KEY=

# Target board + group for trial enquiries. Both have hardcoded defaults in
# src/lib/apis/monday.ts (board 18413002067, group "topics" = Free Trial), so
# leave these blank to use them. The column IDs (name/email/mobile/dates/file)
# are hardcoded in that file — change them there, not via env.
MONDAY_ENQUIRY_BOARD_ID=
MONDAY_ENQUIRY_GROUP_ID=
