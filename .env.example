# =========================================================================
# Stayful Intelligence — environment variables
# Copy to `.env.local` for local dev. Set the same vars on Vercel for prod.
# =========================================================================

# ── Supabase (auth + profiles DB) ────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe (PLACEHOLDER — checkout not yet wired, env vars unused) ───────
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=

# ── App ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Analyser data partners (required by /api/analyse) ────────────────────
AIRBTICS_API_KEY=
AIRBTICS_BASE_URL=
PROPERTYDATA_API_KEY=
GOOGLE_PLACES_API_KEY=
TICKETMASTER_API_KEY=

# Dev-only: lets scripts/calibrate.mjs bypass auth + trial gate on
# /api/analyse. Do NOT set on production.
CALIBRATION_BYPASS_SECRET=

# ── Monday CRM ───────────────────────────────────────────────────────────
# Same API key powers /api/track (engagement → leads board 5891626711)
# AND src/lib/monday/trial.ts (trial signups → board 18412564741).
MONDAY_API_KEY=

# Production board ID + column IDs are hardcoded as defaults in
# src/lib/monday/trial.ts. Leave these blank to use the defaults; set
# them only if you want to point at a different board (e.g. staging).
# See https://stayful.monday.com/boards/18412564741 for the live board.
MONDAY_TRIAL_BOARD_ID=
MONDAY_TRIAL_COL_EMAIL=
MONDAY_TRIAL_COL_MOBILE=
MONDAY_TRIAL_COL_SIGNUP_AT=
MONDAY_TRIAL_COL_TRIAL_ENDS_AT=
MONDAY_TRIAL_COL_REPORTS_RUN=
MONDAY_TRIAL_COL_LAST_SEEN_AT=
MONDAY_TRIAL_COL_STATUS=
