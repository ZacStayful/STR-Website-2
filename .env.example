# =========================================================================
# Stayful Intelligence — environment variables
# Copy to `.env.local` for local dev. Set the same vars on Vercel for prod.
# =========================================================================

# ── Supabase (auth + profiles DB) ────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe (PLACEHOLDER — checkout not yet wired, env vars unused) ───────
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=

# ── App ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Analyser data partners (required by /api/analyse) ────────────────────
AIRBTICS_API_KEY=
AIRBTICS_BASE_URL=
PROPERTYDATA_API_KEY=
GOOGLE_PLACES_API_KEY=
TICKETMASTER_API_KEY=

# Dev-only: lets scripts/calibrate.mjs bypass auth + trial gate on
# /api/analyse. Do NOT set on production.
CALIBRATION_BYPASS_SECRET=

# ── Monday CRM ───────────────────────────────────────────────────────────
# Same API key powers /api/track (engagement to leads board 5891626711)
# AND /lib/monday/trial.ts (trial signups → new dedicated board).
MONDAY_API_KEY=

# New "Trial signups" board — until BOARD_ID + COL_* are set, the trial
# hooks no-op. Create a Monday board with these columns:
#   • Email          — Text
#   • Full name      — Text
#   • Mobile         — Text
#   • Signup at      — Date
#   • Trial ends at  — Date
#   • Reports run    — Numbers
#   • Last seen at   — Date
#   • Plan           — Status (labels: "Free", "Pro")
# Then grab the column IDs (Monday UI: column → Settings → Customise →
# Column ID) and paste them below. Board ID is the digits in the URL.
MONDAY_TRIAL_BOARD_ID=
MONDAY_TRIAL_COL_EMAIL=
MONDAY_TRIAL_COL_NAME=
MONDAY_TRIAL_COL_MOBILE=
MONDAY_TRIAL_COL_SIGNUP_AT=
MONDAY_TRIAL_COL_TRIAL_ENDS_AT=
MONDAY_TRIAL_COL_REPORTS_RUN=
MONDAY_TRIAL_COL_LAST_SEEN_AT=
MONDAY_TRIAL_COL_PLAN=
